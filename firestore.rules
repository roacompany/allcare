rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 사용자별 데이터 ---
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // babies 및 하위 컬렉션 (activities, growth, diary, vaccinations, milestones)
      match /babies/{babyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        match /{subcollection}/{docId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // 공유된 아기: sharedAccess 문서가 존재하면 타 사용자 데이터 접근 허용
      match /babies/{babyId} {
        allow read: if request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid)/sharedAccess/$(userId + "_" + babyId));
        match /{subcollection}/{docId} {
          allow read: if request.auth != null
            && exists(/databases/$(database)/documents/users/$(request.auth.uid)/sharedAccess/$(userId + "_" + babyId));
        }
      }

      // todos, routines, products — 본인만
      match /todos/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /routines/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /products/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // sharedAccess — 본인만
      match /sharedAccess/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // FCM 토큰 — 본인만
      match /fcmTokens/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // --- 초대 ---
    match /invites/{inviteId} {
      // 인증 사용자 읽기 (초대 코드 조회)
      allow read: if request.auth != null;
      // 소유자만 생성 (ownerUserId == 본인)
      allow create: if request.auth != null
        && request.resource.data.ownerUserId == request.auth.uid;
      // 소유자만 수정 (isUsed 마킹 등)
      allow update: if request.auth != null
        && resource.data.ownerUserId == request.auth.uid;
    }

    // --- 공지사항: 인증 사용자 읽기, 관리자만 쓰기 ---
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == "8EAUezvUyYTzhNVw9VO6GKKyhhx2";
    }
  }
}
