rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- 사용자별 데이터 ---
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // babies 및 하위 컬렉션 (activities, growth, diary, vaccinations, milestones)
      match /babies/{babyId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        match /{subcollection}/{docId} {
          allow read, write: if request.auth != null && request.auth.uid == userId;
        }
      }

      // 공유된 아기: sharedAccess 문서가 존재하면 타 사용자 데이터 읽기+쓰기 허용
      match /babies/{babyId} {
        allow read, write: if request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid)/sharedAccess/$(userId + "_" + babyId));
        match /{subcollection}/{docId} {
          allow read, write: if request.auth != null
            && exists(/databases/$(database)/documents/users/$(request.auth.uid)/sharedAccess/$(userId + "_" + babyId));
        }
      }

      // 사용자 레벨 서브컬렉션 — 본인만
      match /todos/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /routines/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /products/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /hospitalVisits/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /vaccinations/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /milestones/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /diary/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /purchases/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /premiumStatus/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // sharedAccess — 본인만
      match /sharedAccess/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // FCM 토큰 — 본인만
      match /fcmTokens/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // 배지 — 본인만 읽기/쓰기 (FirestoreService+Badge: 중복 방지 get→set 단일 경로)
      match /badges/{badgeId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // 누적 통계 — 본인만 읽기/쓰기 (FieldValue.increment + merge:true)
      match /stats/{statsId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // --- 임신 모드 (Pregnancy Mode) ---
      // 임신 루트 문서: 본인 또는 파트너(sharedWith 포함) 읽기, 쓰기는 본인만
      match /pregnancies/{pregnancyId} {
        allow read: if request.auth != null
          && (
            request.auth.uid == userId
            || (resource != null && resource.data.sharedWith is list
                && request.auth.uid in resource.data.sharedWith)
          );
        allow write: if request.auth != null && request.auth.uid == userId;

        // 임신 하위 서브컬렉션 (kickSessions, prenatalVisits, pregnancyChecklists, pregnancyWeights)
        match /{subcollection}/{docId} {
          allow read: if request.auth != null
            && (
              request.auth.uid == userId
              || (
                exists(/databases/$(database)/documents/users/$(userId)/pregnancies/$(pregnancyId))
                && get(/databases/$(database)/documents/users/$(userId)/pregnancies/$(pregnancyId)).data.sharedWith is list
                && request.auth.uid in get(/databases/$(database)/documents/users/$(userId)/pregnancies/$(pregnancyId)).data.sharedWith
              )
            );
          allow write: if request.auth != null && request.auth.uid == userId;
        }
      }
    }

    // --- 임신 모드 collectionGroup: 파트너 read (sharedWith) ---
    // collectionGroup 쿼리 (fetchSharedPregnancy) 지원: sharedWith 포함 사용자 read 허용
    match /{path=**}/pregnancies/{pregnancyId} {
      allow read: if request.auth != null
        && resource != null
        && resource.data.sharedWith is list
        && request.auth.uid in resource.data.sharedWith;
    }

    // --- 초대 ---
    match /invites/{inviteId} {
      // 인증 사용자 읽기 (초대 코드 조회)
      allow read: if request.auth != null;
      // 소유자만 생성 (ownerUserId == 본인)
      allow create: if request.auth != null
        && request.resource.data.ownerUserId == request.auth.uid;
      // 소유자만 수정 또는 인증 사용자가 isUsed만 true로 변경
      allow update: if request.auth != null
        && (
          resource.data.ownerUserId == request.auth.uid
          || (
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(["isUsed"])
            && request.resource.data.isUsed == true
            && resource.data.isUsed == false
          )
        );
      // 소유자만 삭제
      allow delete: if request.auth != null && resource.data.ownerUserId == request.auth.uid;
    }

    // --- 공지사항: 인증 사용자 읽기, 관리자만 쓰기 ---
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == "8EAUezvUyYTzhNVw9VO6GKKyhhx2";
    }

    // --- 상품 카탈로그: 인증 사용자 읽기, 관리자만 쓰기 ---
    match /productCatalog/{productId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.uid == "8EAUezvUyYTzhNVw9VO6GKKyhhx2";
    }
  }
}
